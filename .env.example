# Copy this file to .env and fill in real values. Do not commit .env.
# 텔레그램 봇
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# 콤마로 구분된 텔레그램 user id (비워두면 누구나 사용 가능)
TELEGRAM_ALLOWED_USER_IDS=

# Qdrant
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=company_docs

# LLM CLI (API 키 사용 안 함, 로그인된 CLI 호출)
# 예) codex 사용 시:        LLM_CLI=codex,         LLM_CLI_ARGS=exec
#     claude code 사용 시:  LLM_CLI=claude,        LLM_CLI_ARGS=-p
#     gemini 사용 시:       LLM_CLI=gemini,        LLM_CLI_ARGS=-p
LLM_CLI=codex
# --skip-git-repo-check : codex 가 비-git 디렉토리에서도 동작하도록 허용
# -m gpt-5.4-mini       : 테스트용 작은 모델 (단가 낮음)
# -c model_reasoning_effort=low : reasoning 토큰 최소화
# 운영 시 품질 우선이면 위 두 옵션 제거 → ~/.codex/config.toml 의 기본 (gpt-5.5/high) 사용
LLM_CLI_ARGS=exec --skip-git-repo-check -m gpt-5.4-mini -c model_reasoning_effort=low
LLM_CLI_TIMEOUT=180

# 로컬 임베딩 모델 (HuggingFace 자동 다운로드)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# 리랭커 (cross-encoder, 로컬, ~570MB 최초 다운로드)
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Retrieval & rerank 단계
# RETRIEVE_K: Qdrant 1차 후보 (RERANKER_ENABLED=true 일 때만 사용)
# TOP_K     : 리랭커가 고른 최종 청크 수 (LLM 입력)
RETRIEVE_K=20
TOP_K=5

# 자동 인덱싱
# WATCHER_ENABLED=true 면 봇과 함께 watchdog 이 data/docs/ 를 감시하여
# 파일 생성/수정/삭제 시 증분 인덱싱 (BGE-M3 재계산은 변경된 source 만)
WATCHER_ENABLED=true
